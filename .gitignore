# =========================
# 1. VS Code 个人配置
# =========================
**/.vscode/

# =========================
# 2. C/C++ 编译生成的临时文件和可执行文件
# =========================
**/*.o
**/*.obj
**/*.out
**/*.exe
**/*.dll
**/*.so
**/*.dylib

# =========================
# 3. 常见的构建/输出目录 (CMake 或手写 Makefile 常用)
# =========================
**/build/
**/bin/
**/out/
**/Debug/
**/Release/

# =========================
# 4. 操作系统产生的垃圾文件
# =========================
**/.DS_Store
**/Thumbs.db

# =========================
# Python 缓存文件
# =========================
**/__pycache__/
*.py[cod]
*$py.class

# =========================
# Python 虚拟环境
# =========================
**/venv/
**/env/
**/.venv/
**/.env/

# =========================
# 密码与隐私配置
# =========================
**/.env

# =========================
# Jupyter Notebook 缓存
# =========================
**/.ipynb_checkpoints/

# =========================
# Hugo 生成的网页成品与缓存 (切勿上传)
# =========================
public/
resources/
.hugo_build.lock